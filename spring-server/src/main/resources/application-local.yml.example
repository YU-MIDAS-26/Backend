# 이 파일을 복사해서 application-local.yml로 저장한 뒤 본인 환경 값으로 채우세요.
# application-local.yml은 .gitignore되어 있어 git에 올라가지 않습니다.
#
#   cp application-local.yml.example application-local.yml

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/bsight?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
    username: your_username
    password: your_password
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

# ===== JWT =====
jwt:
  secret: replace-with-a-secret-key-at-least-256-bits-long-for-hs256
  expiration: 86400000

# ===== KAMIS (시크릿) =====
# 발급: https://www.kamis.or.kr/customer/reference/openapi_list.do
kamis:
  cert-key: your-kamis-cert-key
  cert-id: your-kamis-cert-id

# ===== Naver Shopping (시크릿) =====
# 발급: https://developers.naver.com/apps/  (검색 API 사용 체크)
naver:
  client-id: your-naver-client-id
  client-secret: your-naver-client-secret

# ===== OpenAI (시크릿) =====
# 발급: https://platform.openai.com/api-keys
openai:
  api-key: your-openai-api-key

# ===== Logging =====
logging:
  level:
    com.bsight.springserver: DEBUG
    org.hibernate.SQL: DEBUG
