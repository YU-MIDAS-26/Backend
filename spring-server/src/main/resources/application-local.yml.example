spring:
  datasource:
    url: jdbc:mysql://localhost:3306/bsight?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
    username: your_username
    password: your_password
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

# ===== JWT =====
jwt:
  secret: replace-with-a-secret-key-at-least-256-bits-long-for-hs256
  expiration: 86400000

# ===== KAMIS (시크릿) =====
kamis:
  cert-key: your-kamis-cert-key
  cert-id: your-kamis-cert-id

# ===== Naver Shopping (시크릿) =====
naver:
  client-id: your-naver-client-id
  client-secret: your-naver-client-secret

# ===== Logging =====
logging:
  level:
    com.bsight.springserver: DEBUG
    org.hibernate.SQL: DEBUG
